# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Data files
*.xlsx binary
*.xls binary
*.json text eol=lf
*.csv text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
